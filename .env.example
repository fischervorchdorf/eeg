# Database (Hostinger MySQL - eigene DB, NICHT regions-app!)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=eeg_portal
# SSL-Zertifikatspruefung: Standard ist true (sicher)
# Nur auf false setzen wenn DB-Server kein gueltiges Zertifikat hat
DB_SSL_REJECT_UNAUTHORIZED=false
# SSL komplett deaktivieren (nur lokale Entwicklung ohne SSL):
# DB_SSL=false

# Server
PORT=3000
NODE_ENV=development

# S3 / Cloudflare R2 (Dokument-Upload)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=eeg-portal
S3_PUBLIC_URL=

# Email (SMTP - MUSS in Produktion konfiguriert sein!)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eeg-portal.at

# Cron Jobs
ENABLE_CRON=false

# Base URL (fuer Links in Emails)
BASE_URL=http://localhost:3000

# OCR (Google Gemini Flash)
GEMINI_API_KEY=
